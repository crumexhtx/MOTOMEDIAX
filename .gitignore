# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated validation report
catalog-validation.json
catalog-image-audit.json

# catalog build API cache (regenerate with pnpm build:catalog)
scripts/.cache/

# Prefer committing optimized local photos under public/catalog/ so deploys
# stay fast without a live Wikimedia download. Regenerate with:
#   pnpm backfill:images && pnpm localize:images
# (or pnpm build:catalog). Uncomment the next line only for local scratch dirs:
# public/catalog/
